doctype html
html[data-theme="dark" lang="en"]
  head
    meta[charset="UTF-8"]
    meta[content="width=device-width, initial-scale=1.0" name="viewport"]
    title Cone Light MK.II System
    style == css
    script == js
  body
    #embed_cone_light_icon[data-blob="data:image/svg+xml;base64,"]
    #embed_cone_light_logo[data-blob="data:image/svg+xml;base64,"]

    dialog#dialog
      .card
        .column
          img.cone_light_logo
          h2 Cone Light MK.II System
          p Connecting...
          progress

    .container
      h2[style="text-align: center"] Cone Light MK.II System
      -# REMOTE HEADER
      .card
        .row[style="justify-content: space-between; vertical-align: center"]
          b#remote_node_name 8:REMOTE
          p#remote_node_version[style="margin: auto 0; font-family: monospace"] v0000.00.00 p00
          meter#remote_node_voltage[value="5.241" title="5.241v"] 0.000v

      -# NODE GROUPS
      #node_groups

      hr

      -# LED CONTROL
      .card
        details
          summary LED Control
          .row
            .item
              label Choose color
              input#led_control_color[type="color" value="#ffffff"]
            .item
              label[for="led_control_brightness"] Choose brightness
              input#led_control_brightness[name="led_control_brightness" type="range" min="0" max="255" value="25"]
              p#led_control_brightness_label 25
            .item
              label[for="led_control_select_node"] Choose node or group
              select#led_control_select_node.select_node[name="led_control_select_node"]
            .item.action
              .row[style="justify-content: space-evenly"]
                label[for="led_control_auto_update"]
                  input#led_control_auto_update[name="led_control_auto_update" type="checkbox"]
                  span Auto update?
                label[for="led_control_brightness_only"]
                  input#led_control_brightness_only[name="led_control_brightness_only" type="checkbox"]
                  span Apply brightness only?
              p &nbsp;
              input#led_control_submit[type="button" value="UPDATE"]

      -# TONE CONTROL
      .card
        details
          summary Tone Control
          .row
            .item
              label[for="tone_control_select_tone"] Choose tone
              select#tone_control_select_tone[name="tone_control_select_tone"]
            .item
              label[for="tone_control_select_duration"] Choose duration
              input#tone_control_select_duration[name="tone_control_select_duration" type="range" min="1" max="10000" value="1000"]
              p#tone_control_duration_label 1 000ms
            .item
              label[for="tone_control_select_node"] Choose node or group
              select#tone_control_select_node.select_node[name="tone_control_select_node"]
            .item.action
              input#tone_control_submit[type="button" value="PLAY"]

      -# SONG CONTROL
      .card
        details
          summary Song Control
          .row
            .item
              label Choose song
              select#song_control_select_song
            .item
              label[for="song_control_select_node"] Choose node or group
              select#song_control_select_node.select_node[name="song_control_select_node"]
            .item.action
              input#song_control_submit[type="button" value="PLAY"]
